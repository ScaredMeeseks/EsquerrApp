rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ─────────────────────────────────────────────
    // HYBRID authorization (Phase 2): Auth custom claims first (fast, no
    // reads — set by joinClub/setRole/backfill), users-doc fallback for
    // sessions whose token predates the claims backfill. The fallback is
    // removed in Phase 3.
    function isSuperUser() {
      return request.auth != null && request.auth.token.email == 'marna96@gmail.com';
    }
    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function sameTeam(teamId) {
      return request.auth != null && (
        request.auth.token.teamId == teamId
        || me().teamId == teamId
      );
    }
    function isStaffOf(teamId) {
      return request.auth != null && (
        (request.auth.token.teamId == teamId
          && request.auth.token.role in ['staff', 'lead'])
        || (me().teamId == teamId
            && (me().isTeamLead == true
                || (('roles' in me()) && me().roles.hasAny(['staff']))))
      );
    }
    function isLeadOf(teamId) {
      return request.auth != null && (
        (request.auth.token.teamId == teamId && request.auth.token.role == 'lead')
        || (me().teamId == teamId && me().isTeamLead == true)
      );
    }
    // Per-record ownership: doc ids are "{uid}" or "{uid}_..."
    function owns(docId) {
      return docId.matches(request.auth.uid + '(_.*)?');
    }

    // ── Users (global; teamId assigned ONLY by the joinClub function) ──
    match /users/{uid} {
      // Own doc, superuser, or members of the same club.
      // Client list queries MUST use where('teamId','==',<own team>).
      allow read: if request.auth != null && (
        request.auth.uid == uid
        || isSuperUser()
        || (resource.data.teamId != null && sameTeam(resource.data.teamId))
      );
      // Self-create without club/privilege fields (joinClub writes those).
      allow create: if isSuperUser() || (
        request.auth != null && request.auth.uid == uid
        && !request.resource.data.keys().hasAny(['teamId', 'isTeamLead', 'isAdmin'])
      );
      allow update: if request.auth != null && (
        isSuperUser()
        // Self: any profile field EXCEPT club membership / privilege flags.
        // (roles self-changes stay allowed transitionally for old clients;
        // new clients route roles through setRole to keep claims in sync)
        || (request.auth.uid == uid
            && !request.resource.data.diff(resource.data).affectedKeys()
                 .hasAny(['teamId', 'isTeamLead', 'isAdmin', 'claimsUpdatedAt']))
        // Staff of the member's club: registration fields only.
        || (resource.data.teamId != null && isStaffOf(resource.data.teamId)
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['roles', 'position', 'playerNumber', 'team', 'category',
                           'fitnessStatus', 'injuryNote']))
      );
      allow delete: if isSuperUser();

      match /tokens/{tokenId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── Teams (all club data lives under teams/{teamId}) ──
    match /teams/{teamId} {
      allow read: if sameTeam(teamId) || isSuperUser();
      allow create, update: if isStaffOf(teamId) || isSuperUser();
      allow delete: if isSuperUser();

      // Legacy blob/merge docs. TRANSITIONAL: players may still write the
      // keys their flows dual-write (old clients depend on them until
      // Phase 3, when this allowlist shrinks to staff-only).
      match /data/{key} {
        allow read: if sameTeam(teamId) || isSuperUser();
        allow write: if isSuperUser() || isStaffOf(teamId)
          || (sameTeam(teamId) && key in [
               'fa_training_availability', 'fa_match_availability', 'fa_player_rpe',
               'fa_injury_notes', 'fa_injury_zone', 'fa_injuries',
               'fa_users', 'fa_staff_notifications'
             ]);
      }

      // Per-record player-submitted data (canonical since Phase 2).
      // Players write ONLY records whose id starts with their uid and
      // whose uid field matches; staff/superuser manage everything.
      match /trainingAvail/{docId} {
        allow read: if sameTeam(teamId) || isSuperUser();
        allow create, update: if isSuperUser() || isStaffOf(teamId)
          || (sameTeam(teamId) && owns(docId)
              && request.resource.data.uid == request.auth.uid);
        allow delete: if isSuperUser() || isStaffOf(teamId)
          || (sameTeam(teamId) && owns(docId));
      }
      match /matchAvail/{docId} {
        allow read: if sameTeam(teamId) || isSuperUser();
        allow create, update: if isSuperUser() || isStaffOf(teamId)
          || (sameTeam(teamId) && owns(docId)
              && request.resource.data.uid == request.auth.uid);
        allow delete: if isSuperUser() || isStaffOf(teamId)
          || (sameTeam(teamId) && owns(docId));
      }
      match /rpe/{docId} {
        allow read: if sameTeam(teamId) || isSuperUser();
        allow create, update: if isSuperUser() || isStaffOf(teamId)
          || (sameTeam(teamId) && owns(docId)
              && request.resource.data.uid == request.auth.uid);
        allow delete: if isSuperUser() || isStaffOf(teamId)
          || (sameTeam(teamId) && owns(docId));
      }

      match /seasons/{seasonId} {
        allow read: if sameTeam(teamId) || isSuperUser();
        allow write: if isSuperUser();

        // Blob archives AND per-record archives (data/, trainingAvail/,
        // matchAvail/, rpe/) — written only by the archiveSeason function.
        match /{archiveColl}/{docId} {
          allow read: if sameTeam(teamId) || isSuperUser();
          allow write: if isSuperUser();
        }
      }

      match /pushQueue/{docId} {
        allow create: if sameTeam(teamId);
        allow read, update, delete: if false;
      }
    }

    // ── Clubs (config readable by members only — the join code is NOT here) ──
    match /clubs/{clubId} {
      allow read: if sameTeam(clubId) || isSuperUser();
      allow create, delete: if isSuperUser();
      allow update: if isSuperUser() || isLeadOf(clubId);
    }

    // ── Club join codes: superuser + Cloud Functions only ──
    match /clubCodes/{code} {
      allow read, write: if isSuperUser();
    }

    // ── joinClub rate-limit counters: Cloud Functions only ──
    match /joinAttempts/{uid} {
      allow read, write: if false;
    }
  }
}
