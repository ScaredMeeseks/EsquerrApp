rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profile pictures: owner can read/write, anyone authenticated can read
    match /profilePics/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Club badges: superuser can write, anyone authenticated can read
    match /clubBadges/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.token.email == 'marna96@gmail.com'
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
